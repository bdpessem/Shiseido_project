# Convert SVG to PNG (in-memory)
svg_raster <- rsvg::rsvg_png("../figures/MMVEC_heatmap_8bars_06142025.svg")
# Convert SVG to PNG (in-memory)
svg_raster <- rsvg::rsvg_png("../figures/Figure6b.svg")
# Convert SVG to PNG (in-memory)
svg_raster <- rsvg::rsvg_png("../figures/main/Figure6b.svg")
# Create raster grob from PNG
svg_grob <- grid::rasterGrob(png::readPNG(svg_raster), interpolate = TRUE)
label_a <- textGrob("a", x = unit(0, "npc"), y = unit(1, "npc"), just = c("left", "top"),
gp = gpar(fontsize = 18, fontface = "bold"))
label_b <- textGrob("b", x = unit(0, "npc"), y = unit(1, "npc"), just = c("left", "top"),
gp = gpar(fontsize = 18, fontface = "bold"))
# Add labels to the plots
plot_a_labeled <- arrangeGrob(heatmap_genera, top = label_a)
plot_b_labeled <- arrangeGrob(svg_grob, top = label_b)
Figure6 <- grid.arrange(plot_a_labeled, plot_b_labeled, nrow = 2)
library(ggplot2)
library(grid)
library(gridExtra)   # for grid.arrange()
library(png)         # for reading PNGs
library(rsvg)        # for SVG → PNG conversion
# Convert SVG to PNG (in-memory)
svg_raster <- rsvg::rsvg_png("../figures/main/Figure6b.svg")
# Create raster grob from PNG
svg_grob <- grid::rasterGrob(png::readPNG(svg_raster), interpolate = TRUE)
label_a <- textGrob("a", x = unit(0, "npc"), y = unit(1, "npc"), just = c("left", "top"),
gp = gpar(fontsize = 18, fontface = "bold"))
label_b <- textGrob("b", x = unit(0, "npc"), y = unit(1, "npc"), just = c("left", "top"),
gp = gpar(fontsize = 18, fontface = "bold"))
# Add labels to the plots
plot_a_labeled <- arrangeGrob(heatmap_genera, top = label_a)
plot_b_labeled <- arrangeGrob(svg_grob, top = label_b)
Figure6 <- grid.arrange(plot_a_labeled, plot_b_labeled, nrow = 2)
ggsave("Figures/metadata/Figure6.svg",
plot = Figure6,
width = 16, height = 18)
