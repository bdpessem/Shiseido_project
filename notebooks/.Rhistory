tax_cols <- setdiff(colnames(df_relative), c("SampleID"))
# Function to extract the correct taxonomic label
extract_lowest_defined_level <- function(tax_string) {
parts <- str_split(tax_string, ";\\s*")[[1]]
parts <- parts[parts != ""]  # remove empty parts
if (length(parts) == 0) return("Unclassified")
last <- parts[length(parts)]
if (str_detect(last, "g__uncultured") && length(parts) > 1) {
return(parts[length(parts) - 1])  # return level above (e.g. family)
} else {
return(last)
}
}
# Apply the function to all taxonomic column names
cleaned_names <- map_chr(tax_cols, extract_lowest_defined_level)
# Get the mapping between new (collapsed) names and original columns
cleaned_names <- map_chr(tax_cols, extract_lowest_defined_level)
# Create a new dataframe with collapsed relative abundances
df_tax_collapsed <- df_relative[, "SampleID", drop=FALSE]  # keep SampleID
for (taxon in unique(cleaned_names)) {
matched_cols <- tax_cols[cleaned_names == taxon]
df_tax_collapsed[[taxon]] <- rowSums(df_relative[, matched_cols, drop=FALSE])
}
row_sums <- rowSums(df_tax_collapsed %>% select(-SampleID))
summary(row_sums)
df_merged2 <- df_tax_collapsed %>%
left_join(Shiseido_metadata, by = c("SampleID" = "#SampleID"))
Shiseido_metadata
df_tax_collapsed
df_merged2 <- df_tax_collapsed %>%
left_join(Shiseido_metadata, by = c("SampleID" = "SampleID_2"))
View(df_merged2)
